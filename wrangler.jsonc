{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "qt",
  "compatibility_date": "2026-04-18",
  "main": "src/index.js",
  "keep_vars": true,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
